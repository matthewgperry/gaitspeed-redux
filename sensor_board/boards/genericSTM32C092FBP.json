{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m0plus",
    "extra_flags": "-DSTM32C0 -DSTM32C0xx -DSTM32C092xx -DARDUINO_GENERIC_C092FBPX",
    "f_cpu": "48000000L",
    "framework_extra_flags": {
      "arduino": "-D__CORTEX_SC=0"
    },
    "mcu": "stm32c092fbp",
    "product_line": "STM32C092xx",
    "variant": "STM32C0xx/C092ECY_C092F(B-C)P"
  },
  "debug": {
    "default_tools": [
      "stlink"
    ],
    "jlink_device": "STM32C092FB",
    "openocd_target": "stm32c0x",
    "svd_path": "STM32C092.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube"
  ],
  "name": "Generic STM32C092FBP",
  "upload": {
    "maximum_ram_size": 30720,
    "maximum_size": 131072,
    "protocol": "stlink",
    "protocols": [
      "stlink",
      "jlink",
      "cmsis-dap",
      "blackmagic",
      "serial"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32c092fb.html",
  "vendor": "Generic"
}
